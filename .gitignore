# ------------------------------
# Secrets and local env files
# ------------------------------
.env
.env.*
**/.env
**/.env.*
!**/.env.example
!.env.example

# Common secret/key file types
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.keystore

# ------------------------------
# Runtime data (keep placeholders)
# ------------------------------
*/data/*
!*/data/.gitkeep

paperless/media/*
!paperless/media/.gitkeep

paperless/export/*
!paperless/export/.gitkeep

paperless/consume/*
!paperless/consume/.gitkeep

ollama/models/*
!ollama/models/.gitkeep

# ------------------------------
# Logs and temp files
# ------------------------------
*.log
*.pid
*.tmp
*.swp
*.swo

# ------------------------------
# IDE/editor files
# ------------------------------
.vscode/
.idea/
*.iml
*.suo
*.user
*.userossc
*.sln.docstates

# ------------------------------
# OS files
# ------------------------------
.DS_Store
Thumbs.db

# ------------------------------
# Docker files (optional, if you want to ignore them)
docker-compose.override.yaml
docker-compose.override.yml

# ------------------------------
# Other files you may want to ignore
# ------------------------------
*.bak
*.backup
*.old
*.orig
*.tmp
*.temp
*.log
*.cache
*.pid
*.swp
*.swo
acme.json
*.gguf
*.crt
*.tmpl
traefik.dynamic.yml
traefik.yml
compose.yaml